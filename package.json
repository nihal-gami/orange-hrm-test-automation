{
  "name": "orange-hrm-automation",
  "version": "1.0.0",
  "description": "Automated test suite for Orange HRM Demo using Playwright and TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:auth": "npx playwright test tests/auth/",
    "test:chrome": "npx playwright test --project=chromium",
    "report": "npx playwright show-report",
    "install:deps": "npx playwright install"
  },
  "keywords": [
    "automation",
    "playwright",
    "typescript",
    "orange-hrm",
    "testing",
    "e2e"
  ],
  "author": "Test Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.9.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
} 