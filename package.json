{
  "name": "orange-hrm-automation",
  "version": "1.0.0",
  "description": "Automated testing suite for Orange HRM using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:auth": "playwright test tests/auth/",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://opensource-demo.orangehrmlive.com"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "orange-hrm",
    "e2e"
  ],
  "author": "Nihal Gami",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.0"
  }
} 